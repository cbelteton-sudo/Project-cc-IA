generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String                        @id @default(uuid())
  name                  String
  slug                  String                        @unique
  logoUrl               String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  auditLogs             AuditLog[]
  contractors           Contractor[]
  contractorAssignments ContractorProjectAssignment[]
  contractorResources   ContractorResource[]
  materials             Material[]
  projects              Project[]
  projectActivities     ProjectActivity[]
  projectMilestones     ProjectMilestone[]
  users                 User[]
}

model User {
  id                   String            @id @default(uuid())
  username             String?           @unique
  email                String?           @unique
  password             String?
  name                 String?
  phone                String?
  role                 String            @default("USER")
  status               String            @default("ACTIVE")
  invitationToken      String?           @unique
  invitationExpires    DateTime?
  tenantId             String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  contractorId         String?
  projectId            String?
  auditLogs            AuditLog[]
  assignedBacklogItems BacklogItem[]
  dailyUpdates         DailyUpdate[]
  impediments          Impediment[]      @relation("ImpedimentOwner")
  notifications        Notification[]
  managedProjects      Project[]         @relation("ProjectManager")
  assignedActivities   ProjectActivity[]
  ledActivities        ProjectActivity[] @relation("CrewLeader")
  projectMemberships   ProjectMember[]
  approvedPOs          PurchaseOrder[]   @relation("POApprover")
  sessions             Session[]
  createdSprints       Sprint[]
  timesheets           Timesheet[]
  contractor           Contractor?       @relation(fields: [contractorId], references: [id])
  projectSpecific      Project?          @relation("ProjectSpecificUsers", fields: [projectId], references: [id])
  tenant               Tenant            @relation(fields: [tenantId], references: [id])

  costLedgerEntries    CostLedger[]
  materialConsumptions ActivityMaterial[] @relation("ReportedBy")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  resource   String   @default("UNKNOWN")
  resourceId String?
  tenantId   String
  projectId  String?
  userId     String?
  metadata   String   @default("{}")
  diff       String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  project    Project? @relation(fields: [projectId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model Project {
  id                    String                        @id @default(uuid())
  name                  String
  description           String?
  code                  String?
  status                String                        @default("ACTIVE")
  tenantId              String
  currency              String                        @default("GTQ")
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  startDate             DateTime?
  endDate               DateTime?
  globalBudget          Float?
  clientName            String?
  mainContractorId      String?
  projectManagerId      String?
  enableReports         Boolean                       @default(false)
  enablePMDashboard     Boolean                       @default(false)
  enableOfflineQueue    Boolean                       @default(false)
  enablePunchListPro    Boolean                       @default(false)
  enableGanttPro        Boolean                       @default(false)
  enableScrum           Boolean                       @default(false)
  enableBudget          Boolean                       @default(false)
  enableFieldManagement Boolean                       @default(false)
  enableMaterials       Boolean                       @default(false)
  managerName           String?
  costCenters           Json?
  auditLogs             AuditLog[]
  backlogItems          BacklogItem[]
  budgets               Budget[]
  changeOrders          ChangeOrder[]
  projectContractors    Contractor[]                  @relation("ProjectContractors")
  contractorAssignments ContractorProjectAssignment[]
  costLedger            CostLedger[]
  dailyUpdates          DailyUpdate[]
  expenses              Expense[]
  fieldDailyReports     FieldDailyReport[]
  fieldUpdates          FieldUpdate[]
  impediments           Impediment[]
  inspections           Inspection[]
  invoices              Invoice[]
  issues                Issue[]
  materialRequests      MaterialRequest[]
  measurementTemplates  MeasurementTemplate[]
  photos                Photo[]
  mainContractor        Contractor?                   @relation("ProjectMainContractor", fields: [mainContractorId], references: [id])
  projectManager        User?                         @relation("ProjectManager", fields: [projectManagerId], references: [id])
  tenant                Tenant                        @relation(fields: [tenantId], references: [id])
  activities            ProjectActivity[]
  members               ProjectMember[]
  milestones            ProjectMilestone[]
  purchaseOrders        PurchaseOrder[]
  rfis                  RFI[]
  rfqs                  RFQ[]
  sprints               Sprint[]
  subcontracts          Subcontract[]
  timesheets            Timesheet[]
  projectSpecificUsers  User[]                        @relation("ProjectSpecificUsers")
  projectMaterials      ProjectMaterial[]
  comments              Comment[]
  notifications         Notification[]
}

model Budget {
  id          String       @id @default(uuid())
  projectId   String
  name        String       @default("General Budget")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [id])
  budgetLines BudgetLine[]
}

model BudgetLine {
  id                 String              @id @default(uuid())
  budgetId           String
  wbsActivityId      String?
  costType           String              @default("MATERIAL")
  code               String?
  name               String
  budgetBase         Float               @default(0)
  budgetCO           Float               @default(0)
  budgetTransfer     Float               @default(0)
  amountParam        Float               @default(0)
  amountCommitted    Float               @default(0)
  amountExecuted     Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  budget             Budget              @relation(fields: [budgetId], references: [id])
  wbsActivity        ProjectActivity?    @relation("BudgetLineWbs", fields: [wbsActivityId], references: [id])
  changeOrderItems   ChangeOrderItem[]
  expenses           Expense[]
  invoiceAllocations InvoiceAllocation[]
  activities         ProjectActivity[]   @relation("BudgetLineActivities")
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([budgetId, wbsActivityId, costType])
}

model CostLedger {
  id             String           @id @default(uuid())
  projectId      String
  date           DateTime         @default(now())
  wbsActivityId  String?
  costType       String
  entryType      String
  amount         Float
  referenceId    String?
  description    String?
  documentUrl    String?
  documentNumber String?
  userId         String?
  createdAt      DateTime         @default(now())
  project        Project          @relation(fields: [projectId], references: [id])
  wbsActivity    ProjectActivity? @relation(fields: [wbsActivityId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
}

model MaterialRequest {
  id        String   @id @default(uuid())
  projectId String
  title     String
  status    String   @default("DRAFT")
  items     String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  projectId  String
  vendor     String?
  total      Float               @default(0)
  status     String              @default("DRAFT")
  docStatus  String              @default("DRAFT")
  vendorId   String?
  approverId String?
  notes      String?
  date       DateTime            @default(now())
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  invoices   Invoice[]
  approver   User?               @relation("POApprover", fields: [approverId], references: [id])
  project    Project             @relation(fields: [projectId], references: [id])
  vendorRel  Contractor?         @relation(fields: [vendorId], references: [id])
  items      PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id                String           @id @default(uuid())
  purchaseOrderId   String
  description       String
  quantity          Float
  unitPrice         Float
  total             Float
  budgetLineId      String?
  budgetLine        BudgetLine?      @relation(fields: [budgetLineId], references: [id])
  purchaseOrder     PurchaseOrder    @relation(fields: [purchaseOrderId], references: [id])
  projectMaterialId String?
  projectMaterial   ProjectMaterial? @relation(fields: [projectMaterialId], references: [id])
}

model Invoice {
  id              String              @id @default(uuid())
  projectId       String
  purchaseOrderId String?
  vendor          String?
  invoiceNumber   String
  total           Float
  currency        String              @default("USD")
  exchangeRate    Float               @default(1.0)
  fileUrl         String?
  ocrData         String?
  status          String              @default("PENDING")
  docStatus       String              @default("DRAFT")
  date            DateTime
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  project         Project             @relation(fields: [projectId], references: [id])
  purchaseOrder   PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  allocations     InvoiceAllocation[]
}

model InvoiceAllocation {
  id           String     @id @default(uuid())
  invoiceId    String
  budgetLineId String
  amount       Float
  budgetLine   BudgetLine @relation(fields: [budgetLineId], references: [id])
  invoice      Invoice    @relation(fields: [invoiceId], references: [id])
}

model Expense {
  id           String      @id @default(uuid())
  projectId    String
  status       String      @default("DRAFT")
  date         DateTime
  vendorName   String
  amount       Float
  description  String?
  budgetLineId String?
  attachments  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  budgetLine   BudgetLine? @relation(fields: [budgetLineId], references: [id])
  project      Project     @relation(fields: [projectId], references: [id])
}

model RFI {
  id         String   @id @default(uuid())
  projectId  String
  code       String   @default("RFI-000")
  subject    String   @default("General")
  question   String
  answer     String?
  status     String   @default("OPEN")
  assignedTo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id])
}

model Inspection {
  id        String   @id @default(uuid())
  projectId String
  date      DateTime
  type      String   @default("QUALITY")
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])
}

model ChangeOrder {
  id          String            @id @default(uuid())
  projectId   String
  title       String
  description String?
  amount      Float
  status      String            @default("DRAFT")
  approverId  String?
  approvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     Project           @relation(fields: [projectId], references: [id])
  items       ChangeOrderItem[]
}

model ChangeOrderItem {
  id            String      @id @default(uuid())
  changeOrderId String
  budgetLineId  String
  description   String
  amount        Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  budgetLine    BudgetLine  @relation(fields: [budgetLineId], references: [id])
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
}

model Material {
  id               String            @id @default(uuid())
  tenantId         String
  name             String
  description      String?
  unit             String            @default("UN")
  costParam        Float             @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  projectMaterials ProjectMaterial[]
  comments         Comment[]
}

model RFQ {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  description String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bids        Bid[]
  project     Project  @relation(fields: [projectId], references: [id])
}

model Bid {
  id          String   @id @default(uuid())
  rfqId       String
  vendor      String
  amount      Float
  status      String   @default("PENDING")
  submittedAt DateTime @default(now())
  rfq         RFQ      @relation(fields: [rfqId], references: [id])
}

model Subcontract {
  id          String             @id @default(uuid())
  projectId   String
  vendor      String
  title       String
  totalAmount Float
  startDate   DateTime?
  endDate     DateTime?
  status      String             @default("DRAFT")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  estimates   ProgressEstimate[]
  project     Project            @relation(fields: [projectId], references: [id])
}

model ProgressEstimate {
  id            String      @id @default(uuid())
  subcontractId String
  periodStart   DateTime
  periodEnd     DateTime
  amount        Float
  status        String      @default("SUBMITTED")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  subcontract   Subcontract @relation(fields: [subcontractId], references: [id])
}

model Contractor {
  id                 String                        @id @default(uuid())
  tenantId           String
  name               String
  type               String                        @default("CONTRACTOR")
  email              String?
  phone              String?
  taxId              String?
  address            String?
  legalName          String?
  website            String?
  specialties        String?
  certifications     String?
  insurancePolicy    String?
  bankName           String?
  bankAccount        String?
  contactPersonName  String?
  contactPersonPhone String?
  notes              String?
  isActive           Boolean                       @default(true)
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  projectId          String?
  backlogItems       BacklogItem[]
  project            Project?                      @relation("ProjectContractors", fields: [projectId], references: [id])
  tenant             Tenant                        @relation(fields: [tenantId], references: [id])
  assignments        ContractorProjectAssignment[]
  resources          ContractorResource[]
  issues             Issue[]
  mainProjects       Project[]                     @relation("ProjectMainContractor")
  assignedActivities ProjectActivity[]
  projectMembers     ProjectMember[]
  purchaseOrders     PurchaseOrder[]
  users              User[]
}

model ContractorResource {
  id            String        @id @default(uuid())
  tenantId      String
  contractorId  String
  name          String
  role          String        @default("OPERATOR")
  phone         String?
  email         String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contractor    Contractor    @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  assignedTasks BacklogItem[]

  @@unique([contractorId, email])
}

model ProjectActivity {
  id                    String                   @id @default(uuid())
  tenantId              String
  projectId             String
  parentId              String?
  name                  String
  code                  String?
  startDate             DateTime
  endDate               DateTime
  status                String                   @default("NOT_STARTED")
  percent               Int                      @default(0)
  manualProgress        Int?
  plannedWeight         Float                    @default(1.0)
  orderIndex            Int                      @default(0)
  contractorId          String?
  assignedUserId        String?
  crewLeaderId          String?
  budgetLineId          String?
  measurementType       String                   @default("QUANTITY")
  measurementTemplateId String?
  totalQty              Float?
  unit                  String?
  lastUpdateAt          DateTime                 @default(now())
  blockedReason         String?
  blockedComment        String?
  blockedEta            DateTime?
  blockedOwnerUserId    String?
  committedDate         DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  closureRecord         ActivityClosureRecord?
  dependencies          ActivityDependency[]     @relation("ActivityDependsOn")
  predecessors          ActivityDependency[]     @relation("ActivityPredecessor")
  progressRecords       ActivityWeeklyProgress[]
  backlogItems          BacklogItem[]
  budgetLinesControl    BudgetLine[]             @relation("BudgetLineWbs")
  costLedgerEntries     CostLedger[]
  dailyUpdates          DailyUpdate[]
  fieldDailyEntries     FieldDailyEntry[]
  fieldUpdates          FieldUpdateItem[]
  issues                Issue[]
  photos                Photo[]
  assignedUser          User?                    @relation(fields: [assignedUserId], references: [id])
  budgetLine            BudgetLine?              @relation("BudgetLineActivities", fields: [budgetLineId], references: [id])
  contractor            Contractor?              @relation(fields: [contractorId], references: [id])
  crewLeader            User?                    @relation("CrewLeader", fields: [crewLeaderId], references: [id])
  measurementTemplate   MeasurementTemplate?     @relation(fields: [measurementTemplateId], references: [id])
  parent                ProjectActivity?         @relation("ActivityHierarchy", fields: [parentId], references: [id])
  children              ProjectActivity[]        @relation("ActivityHierarchy")
  project               Project                  @relation(fields: [projectId], references: [id])
  tenant                Tenant                   @relation(fields: [tenantId], references: [id])
  milestones            ProjectMilestone[]
  timesheetEntries      TimesheetEntry[]
  materialConsumptions  ActivityMaterial[]
  comments              Comment[]
}

model ActivityDependency {
  id          String          @id @default(uuid())
  tenantId    String
  projectId   String
  activityId  String
  dependsOnId String
  createdAt   DateTime        @default(now())
  activity    ProjectActivity @relation("ActivityDependsOn", fields: [activityId], references: [id])
  dependsOn   ProjectActivity @relation("ActivityPredecessor", fields: [dependsOnId], references: [id])
}

model ActivityWeeklyProgress {
  id            String          @id @default(uuid())
  tenantId      String
  projectId     String
  activityId    String
  weekStartDate DateTime
  percent       Int             @default(0)
  notes         String?
  createdAt     DateTime        @default(now())
  activity      ProjectActivity @relation(fields: [activityId], references: [id])

  @@unique([activityId, weekStartDate])
}

model ProjectMilestone {
  id          String           @id @default(uuid())
  tenantId    String
  projectId   String
  name        String
  date        DateTime
  description String?
  status      String           @default("PLANNED")
  orderIndex  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  activityId  String?
  activity    ProjectActivity? @relation(fields: [activityId], references: [id])
  project     Project          @relation(fields: [projectId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
}

model ActivityClosureRecord {
  id                  String          @id @default(uuid())
  tenantId            String
  projectId           String
  activityId          String          @unique
  closureCode         String?
  closedAt            DateTime
  pmName              String
  directorName        String
  contractorName      String
  pmSignature         String?
  directorSignature   String?
  contractorSignature String?
  pdfDocumentId       String?
  createdAt           DateTime        @default(now())
  activity            ProjectActivity @relation(fields: [activityId], references: [id])
}

model ContractorProjectAssignment {
  id            String     @id @default(uuid())
  tenantId      String
  contractorId  String
  projectId     String
  assignedAt    DateTime   @default(now())
  roleInProject String?
  status        String     @default("ACTIVE")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  contractor    Contractor @relation(fields: [contractorId], references: [id])
  project       Project    @relation(fields: [projectId], references: [id])
  tenant        Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, contractorId, projectId])
}

model MeasurementTemplate {
  id         String                    @id @default(uuid())
  projectId  String
  name       String
  type       String                    @default("CHECKLIST")
  isDefault  Boolean                   @default(false)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  project    Project                   @relation(fields: [projectId], references: [id])
  items      MeasurementTemplateItem[]
  activities ProjectActivity[]
}

model MeasurementTemplateItem {
  id         String              @id @default(uuid())
  templateId String
  label      String
  weight     Int
  orderIndex Int
  template   MeasurementTemplate @relation(fields: [templateId], references: [id])
}

model FieldUpdate {
  id              String            @id @default(uuid())
  projectId       String
  date            DateTime
  status          String            @default("DRAFT")
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  project         Project           @relation(fields: [projectId], references: [id])
  items           FieldUpdateItem[]
  photos          Photo[]
}

model FieldUpdateItem {
  id                    String          @id @default(uuid())
  fieldUpdateId         String
  activityId            String
  qtyDone               Float?
  checklistState        String?
  milestoneState        String?
  manualPercent         Int?
  notes                 String?
  isRisk                Boolean         @default(false)
  overrideJustification String?
  suggestedPercent      Int?
  confidenceScore       Int?
  deltaFromLast         Int?
  requiresReview        Boolean         @default(false)
  status                String?
  activity              ProjectActivity @relation(fields: [activityId], references: [id])
  fieldUpdate           FieldUpdate     @relation(fields: [fieldUpdateId], references: [id])
}

model Photo {
  id            String           @id @default(uuid())
  projectId     String
  activityId    String?
  fieldUpdateId String?
  urlMain       String
  urlThumb      String?
  width         Int?
  height        Int?
  sizeBytes     Int?
  hash          String?
  dailyEntryId  String?
  capturedAt    DateTime?
  uploadedAt    DateTime         @default(now())
  createdBy     String
  dailyUpdateId String?
  activity      ProjectActivity? @relation(fields: [activityId], references: [id])
  dailyEntry    FieldDailyEntry? @relation(fields: [dailyEntryId], references: [id])
  dailyUpdate   DailyUpdate?     @relation(fields: [dailyUpdateId], references: [id])
  fieldUpdate   FieldUpdate?     @relation(fields: [fieldUpdateId], references: [id])
  project       Project          @relation(fields: [projectId], references: [id])
}

model Issue {
  id                   String           @id @default(uuid())
  projectId            String
  code                 Int?
  type                 String           @default("ISSUE")
  title                String
  description          String?
  severity             String           @default("MEDIUM")
  status               String           @default("OPEN")
  locationBuilding     String?
  locationLevel        String?
  locationZone         String?
  trade                String?
  ownerUserId          String?
  contractorId         String?
  dueDate              DateTime?
  readyForValidationAt DateTime?
  validatedAt          DateTime?
  validatedBy          String?
  reopenedAt           DateTime?
  reopenedBy           String?
  closedAt             DateTime?
  activityId           String?
  createdBy            String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  comments             Comment[]
  activity             ProjectActivity? @relation(fields: [activityId], references: [id])
  contractor           Contractor?      @relation(fields: [contractorId], references: [id])
  project              Project          @relation(fields: [projectId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  createdBy String
  createdAt DateTime @default(now())

  // Polymorphic relations (optional associations)
  issueId    String?
  projectId  String?
  activityId String?
  materialId String?

  issue    Issue?           @relation(fields: [issueId], references: [id])
  project  Project?         @relation(fields: [projectId], references: [id])
  activity ProjectActivity? @relation(fields: [activityId], references: [id])
  material Material?        @relation(fields: [materialId], references: [id])
}

model FieldDailyReport {
  id          String            @id @default(uuid())
  projectId   String
  date        DateTime
  status      String            @default("DRAFT")
  createdBy   String
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entries     FieldDailyEntry[]
  project     Project           @relation(fields: [projectId], references: [id])

  @@unique([projectId, date])
}

model FieldDailyEntry {
  id                 String           @id @default(uuid())
  dailyReportId      String
  scheduleActivityId String?
  wbs                String?
  activityName       String
  status             String
  progressChip       Int?
  note               String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdBy          String?
  dailyReport        FieldDailyReport @relation(fields: [dailyReportId], references: [id])
  activity           ProjectActivity? @relation(fields: [scheduleActivityId], references: [id])
  photos             Photo[]
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  projectId  String?
  type       String
  entityType String
  entityId   String
  message    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
}

model BacklogItem {
  id                           String              @id @default(uuid())
  projectId                    String
  type                         String
  title                        String
  description                  String?
  status                       String              @default("BACKLOG")
  priority                     Int                 @default(3)
  isUrgent                     Boolean             @default(false)
  isImportant                  Boolean             @default(false)
  discipline                   String?
  assigneeUserId               String?
  assigneeContractorResourceId String?
  contractorId                 String?
  linkedWbsActivityId          String?
  parentId                     String?
  storyPoints                  Int?
  estimatedHours               Float?
  definitionOfDone             String?
  evidenceRequired             String              @default("NONE")
  dueDate                      DateTime?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  assigneeUser                 User?               @relation(fields: [assigneeUserId], references: [id])
  assigneeContractorResource   ContractorResource? @relation(fields: [assigneeContractorResourceId], references: [id])
  contractor                   Contractor?         @relation(fields: [contractorId], references: [id])
  linkedWbsActivity            ProjectActivity?    @relation(fields: [linkedWbsActivityId], references: [id])
  parent                       BacklogItem?        @relation("ParentChild", fields: [parentId], references: [id])
  children                     BacklogItem[]       @relation("ParentChild")
  project                      Project             @relation(fields: [projectId], references: [id])
  dailyUpdates                 DailyUpdate[]
  impediments                  Impediment[]
  sprintItems                  SprintItem[]
}

model Sprint {
  id              String        @id @default(uuid())
  projectId       String
  name            String
  goal            String?
  startDate       DateTime
  endDate         DateTime
  status          String        @default("PLANNED")
  createdByUserId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  dailyUpdates    DailyUpdate[]
  impediments     Impediment[]
  retros          Retro[]
  createdByUser   User          @relation(fields: [createdByUserId], references: [id])
  project         Project       @relation(fields: [projectId], references: [id])
  items           SprintItem[]
}

model SprintItem {
  id            String      @id @default(uuid())
  sprintId      String
  backlogItemId String
  boardStatus   String      @default("TODO")
  orderIndex    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  backlogItem   BacklogItem @relation(fields: [backlogItemId], references: [id])
  sprint        Sprint      @relation(fields: [sprintId], references: [id])

  @@unique([sprintId, backlogItemId])
}

model DailyUpdate {
  id            String           @id @default(uuid())
  projectId     String
  userId        String
  sprintId      String?
  backlogItemId String?
  wbsActivityId String?
  text          String
  blocker       String?
  createdAt     DateTime         @default(now())
  backlogItem   BacklogItem?     @relation(fields: [backlogItemId], references: [id])
  project       Project          @relation(fields: [projectId], references: [id])
  sprint        Sprint?          @relation(fields: [sprintId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
  wbsActivity   ProjectActivity? @relation(fields: [wbsActivityId], references: [id])
  photos        Photo[]
}

model Retro {
  id          String   @id @default(uuid())
  sprintId    String
  keep        String?
  improve     String?
  stop        String?
  actionItems String?
  createdAt   DateTime @default(now())
  sprint      Sprint   @relation(fields: [sprintId], references: [id])
}

model Impediment {
  id            String       @id @default(uuid())
  projectId     String
  sprintId      String?
  backlogItemId String?
  title         String
  description   String?
  severity      Int          @default(2)
  status        String       @default("OPEN")
  ownerUserId   String?
  resolvedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  backlogItem   BacklogItem? @relation(fields: [backlogItemId], references: [id])
  ownerUser     User?        @relation("ImpedimentOwner", fields: [ownerUserId], references: [id])
  project       Project      @relation(fields: [projectId], references: [id])
  sprint        Sprint?      @relation(fields: [sprintId], references: [id])
}

model Timesheet {
  id            String           @id @default(uuid())
  projectId     String
  weekStartDate DateTime
  status        String           @default("DRAFT")
  workerName    String?
  userId        String?
  role          String?
  baseRate      Float            @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  project       Project          @relation(fields: [projectId], references: [id])
  user          User?            @relation(fields: [userId], references: [id])
  entries       TimesheetEntry[]
}

model TimesheetEntry {
  id            String           @id @default(uuid())
  timesheetId   String
  date          DateTime
  wbsActivityId String?
  hours         Float
  overtimeHours Float            @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  timesheet     Timesheet        @relation(fields: [timesheetId], references: [id])
  wbsActivity   ProjectActivity? @relation(fields: [wbsActivityId], references: [id])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id           String      @id @default(uuid())
  projectId    String
  userId       String
  role         String      @default("VIEWER")
  contractorId String?
  status       String      @default("ACTIVE")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  contractor   Contractor? @relation(fields: [contractorId], references: [id])
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model SystemRole {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
}

model SystemPermission {
  id          String           @id @default(uuid())
  action      String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   SystemPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         SystemRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model ProjectMaterial {
  id             String   @id @default(uuid())
  projectId      String
  materialId     String
  projectSKU     String? // SKU específico si el proyecto lo requiere
  plannedQty     Float    @default(0) // Cantidad base presupuestada
  plannedPrice   Float    @default(0) // Precio unitario presupuestado
  stockAvailable Float    @default(0) // Cantidad en bodega de la obra
  stockConsumed  Float    @default(0) // Cantidad ya utilizada/instalada
  costCenter     String?  // Centro de costo asignado
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])

  poItems              PurchaseOrderItem[]
  activityConsumptions ActivityMaterial[]

  @@unique([projectId, materialId])
}

model ActivityMaterial {
  id                String   @id @default(uuid())
  projectMaterialId String
  activityId        String
  quantityConsumed  Float    @default(0)
  dateConsumed      DateTime @default(now())
  reportedBy        String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectMaterial ProjectMaterial @relation(fields: [projectMaterialId], references: [id])
  activity        ProjectActivity @relation(fields: [activityId], references: [id])
  reportedByUser  User?           @relation("ReportedBy", fields: [reportedBy], references: [id])
}
